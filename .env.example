# ─── Database ────────────────────────────────────────────────────────────────
# Direct connection (used by Alembic migrations — synchronous psycopg2 style)
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_PASSWORD@ep-damp-truth-ala50gyb.c-3.eu-central-1.aws.neon.tech/neondb
# Pooled connection (used by the app at runtime — lower latency under load)
DATABASE_POOL_URL=postgresql+asyncpg://neondb_owner:YOUR_PASSWORD@ep-damp-truth-ala50gyb-pooler.c-3.eu-central-1.aws.neon.tech/neondb

# ─── AI / LLM ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key               # REQUIRED — used by DSPy for classification
LLM_MODEL=llama-3.1-8b-instant               # Groq model name (used as groq/<model> internally)
LLM_EMBED_MODEL=text-embedding-004           # Gemini embedding model for pgvector
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0                          # deterministic extraction

# ─── Scraping ────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=your-apify-api-token
BRIGHTDATA_API_KEY=                          # leave empty for MVP; fill when migrating

# ─── Modal ───────────────────────────────────────────────────────────────────
# Set via: modal token set --token-id ... --token-secret ...
# These are only needed if passing programmatically
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ─── Processing ──────────────────────────────────────────────────────────────
BATCH_SIZE=20                                # posts per processing batch
MAX_RETRIES=3
SCRAPE_OVERLAP_HOURS=1                       # hours to look back before last_post_timestamp

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                      # development | production
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production
